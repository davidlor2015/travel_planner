# ─────────────────────────────────────────────
# Waypoint — Backend Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# [REQUIRED] PostgreSQL connection string.
# Default matches the docker-compose.yml credentials.
DATABASE_URL=postgresql+psycopg2://planner_user:secret@localhost:5432/travel_planner

# ── Auth ──────────────────────────────────────
# [REQUIRED] Must be at least 32 characters. Do not use a placeholder in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=48
TRIP_INVITE_EXPIRE_DAYS=14

# ── App ───────────────────────────────────────
# Base URL of the web frontend (used in email links).
APP_BASE_URL=http://localhost:5173

# Set to true to expose raw token links in API responses (local dev only).
EXPOSE_DEBUG_LINKS=false

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── LLM Provider ──────────────────────────────
# "ollama" (default, local) or "gemini" (cloud).
LLM_PROVIDER=ollama

# ── Ollama (local LLM) ────────────────────────
# Only used when LLM_PROVIDER=ollama.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_NUM_PREDICT=8192

# ── Gemini (cloud LLM) ────────────────────────
# Only used when LLM_PROVIDER=gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Rate Limiting ─────────────────────────────
# slowapi syntax: "<count>/<period>" e.g. "10/minute", "100/hour"
AI_RATE_LIMIT=10/minute
AI_STREAM_RATE_LIMIT=5/minute
EXECUTION_RATE_LIMIT=30/minute

# ── Optional Integrations ─────────────────────
# Amadeus travel search — leave empty to disable search endpoints.
# Sign up at https://developers.amadeus.com (free self-service sandbox).
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# OpenTripMap — used by the /plan-smart rule-based endpoint.
# Get a free key at https://opentripmap.io/
OPENTRIPMAP_API_KEY=

# ── Sentry (error monitoring) ─────────────────
# Leave empty to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0
