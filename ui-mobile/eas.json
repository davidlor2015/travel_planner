{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://trippilot.onrender.com",
        "EXPO_PUBLIC_ENABLE_EXPLORE": "true"
      }
    },
    "testflight": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://trippilot.onrender.com",
        "EXPO_PUBLIC_ENABLE_EXPLORE": "true"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://trippilot.onrender.com",
        "EXPO_PUBLIC_ENABLE_EXPLORE": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
